{
    "name": "react-native-gpui",
    "version": "0.1.23",
    "description": "Write React Native components, render them natively with GPUI (Zed's GPU UI framework).",
    "type": "module",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "native",
        "README.md"
    ],
    "scripts": {
        "build": "npm run build:rust && npm run build:native && npm run build:ts",
        "build:rust": "cd ../rust && PATH=/opt/homebrew/opt/zig@0.15/bin:$PATH cargo build --release --bin rngpui-service",
        "build:native": "node scripts/build-native.mjs",
        "build:clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
        "build:types": "tsc --emitDeclarationOnly",
        "build:bundle": "bun build src/index.ts --outfile dist/index.js --target node --format esm --external react --external react/jsx-runtime --external react/jsx-dev-runtime",
        "build:ts": "npm run build:clean && npm run build:types && npm run build:bundle",
        "typecheck": "tsc --noEmit",
        "test": "bun run scripts/test-suite.mjs",
        "test:animated-driver": "bun run scripts/animated-driver-unit.mjs",
        "kitchen": "bun run examples/kitchen-sink.tsx",
        "conformance:animation": "bun run examples/animation-conformance.tsx",
        "conformance:animation:diff": "bun run scripts/animation-frame-diff.mjs",
        "conformance:webview:render": "bun run scripts/webview-render-conformance.mjs",
        "conformance:webview:overlay": "bun run scripts/webview-overlay-conformance.mjs",
        "conformance:file-picker": "bun run scripts/file-picker-conformance.ts",
        "conformance:display-none": "bun run scripts/display-none-conformance.ts",
        "conformance:inspector": "node scripts/inspector-conformance.mjs",
        "conformance:input": "node scripts/input-conformance-driver.mjs",
        "conformance:input:manual": "bun run examples/input-conformance.tsx",
        "conformance:list-group": "node scripts/list-group-conformance-driver.mjs",
        "conformance:measure": "RNGPUI_NO_ACTIVATE=1 RNGPUI_TEST_MODE=1 bun run examples/measure-conformance.tsx",
        "conformance:native-layout": "RNGPUI_NO_ACTIVATE=1 RNGPUI_TEST_MODE=1 bun run examples/native-layout-conformance.tsx",
        "conformance:native-layout-animation": "RNGPUI_NO_ACTIVATE=1 RNGPUI_TEST_MODE=1 bun run examples/native-layout-animation-conformance.tsx",
        "conformance:portal": "bun run examples/portal-conformance.tsx",
        "conformance:rounded-overflow": "bun run scripts/rounded-overflow-conformance.mjs",
        "conformance:text-lines": "bun run scripts/text-lines-conformance.mjs",
        "pixel-diff": "bun run scripts/pixel-diff.mjs",
        "pixel-sample": "bun run scripts/pixel-sample.mjs",
        "png-grid": "bun run scripts/png-grid.mjs",
        "test:pixel": "bun run scripts/pixel.test.mjs",
        "superconductor": "bun run examples/superconductor.tsx",
        "prepublishOnly": "npm run build"
    },
    "os": [
        "darwin"
    ],
    "cpu": [
        "arm64"
    ],
    "keywords": [
        "react-native",
        "gpui",
        "zed",
        "rust",
        "desktop",
        "macos",
        "react-reconciler"
    ],
    "license": "MIT",
    "peerDependencies": {
        "react": ">=19.0.0"
    },
    "dependencies": {
        "react-reconciler": "^0.31.0"
    },
    "devDependencies": {
        "@types/node": "25.9.1",
        "@types/react": "^19.0.0",
        "@types/react-reconciler": "^0.31.0",
        "react": "^19.0.0",
        "typescript": "^5.7.0"
    }
}
